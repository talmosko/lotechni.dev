---
import Layout from '@layouts/Layout.astro'
import ContributorsSection from '@sections/contributors/ContributorsSection.astro'
import Heading from '@components/astro/typography/Heading.astro'
import SectionContainer from '@components/astro/containers/SectionContainer.astro'
import Description from '@sections/common/Description.astro'
import type { Props as SEOProps } from 'astro-seo'
import meirJC from '@assets/images/contributors/meirJC.webp'
import afekSk from '@assets/images/contributors/afekSk.webp'
import saarDa from '@assets/images/contributors/saarDa.webp'
import shmuelCo from '@assets/images/contributors/shmuelCo.webp'

const siteContributors = [
  {
    name: 'מאיר יוסף כהן',
    subtitle: 'Meir Josef Cohen',
    image: meirJC,
    description:
      'מאיר יוסף כהן, מפתח פרונטאנד/פולסטאק בהווה, מוסיקאי בעבר, משתדל לא לשבור יותר מדי דברים בדרך.',
    socials: [
      { icon: 'linkedin' as const, url: 'https://www.linkedin.com/in/meirjcohen/' },
      { icon: 'github' as const, url: 'https://github.com/meirjcohen' },
    ],
  },
  {
    name: 'סער דוידסון',
    subtitle: 'Saar Davidson',
    image: saarDa,
    description: 'סער דוידסון הוא מפתח פרונטאנד מומחה בטכנולוגיות כמו טייפסקטריפט, ריאקט ונקסט, ויוצר תוכן בליקדאין עבור מפתחי תוכנה.',
    socials: [
      { icon: 'linkedin' as const, url: 'https://www.linkedin.com/in/saar-davidson/' },
      { icon: 'github' as const, url: 'https://github.com/saar-davidson' },
    ],
  },
  {
    name: 'אפק סקג׳ו',
    subtitle: 'Afek Sakaju',
    image: afekSk,
    description: 'אפק סקג׳ו הוא מפתח פרונטאנד/פולסטאק, מומחה בריאקט ונקסט, צופה אנימה הדוק בזמנו הפנוי.',
    socials: [
      { icon: 'linkedin' as const, url: 'https://www.linkedin.com/in/afeksa/' },
      { icon: 'github' as const, url: 'https://github.com/Afek-Sakaju' },
    ],
  },
  {
    name: 'שמואל כהן',
    subtitle: 'Shmuel Cohen',
    image: shmuelCo,
    description: 'שמואל כהן הוא מפתח פרונטאנד, אבא ומוזיקאי בפוטנציאל.',
    socials: [
      { icon: 'linkedin' as const, url: 'https://www.linkedin.com/in/shmuel-c/' },
      { icon: 'github' as const, url: 'https://github.com/shmuel-c' },
    ],
  },
]

const contributorNames = siteContributors.map((c) => c.subtitle).join(', ')

const pageSEO: Partial<SEOProps> = {
  title: 'צוות האתר - לא טכני',
  description: `הכירו את צוות המתנדבים שבנו את האתר: ${contributorNames}`,
  openGraph: {
    basic: {
      title: 'צוות האתר - לא טכני',
      type: 'website',
      image: '/og-default.png',
      url: Astro.url.href,
    },
    optional: {
      description: `הכירו את צוות המתנדבים שבנו את האתר: ${contributorNames}`,
    },
  },
}
---

<Layout title={'צוות האתר'} seo={pageSEO}>
  <Description
    description={'אנחנו רוצים להודות לצוות המתנדבים המדהים שלנו, שבזכותם האתר הזה קם והתאפשר. הכישרון והמסירות שלהם הפכו את החזון שלנו למציאות.'}
  />

  <SectionContainer>
    <Heading level={2} className="text-center">המתנדבים שבנו את האתר</Heading>
  </SectionContainer>

  <ContributorsSection contributors={siteContributors} />
</Layout>
