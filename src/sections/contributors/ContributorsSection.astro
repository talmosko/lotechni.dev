---
import SectionContainer from '@components/astro/containers/SectionContainer.astro'
import PersonCard from '@components/astro/cards/PersonCard.astro'
import type { ImageMetadata } from 'astro'
import type { SocialLink } from '@data/types/icons'

interface Contributor {
  name: string
  subtitle?: string
  image: ImageMetadata
  description: string
  socials: SocialLink[]
}

interface Props {
  contributors: Contributor[]
}

const { contributors } = Astro.props
---

<SectionContainer innerClasses="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8">
  {contributors.map((contributor) => <PersonCard {...contributor} />)}
</SectionContainer>
