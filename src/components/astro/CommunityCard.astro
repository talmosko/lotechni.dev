---
import ImageContainer from '@components/astro/containers/ImageContainer.astro'
import Heading from '@components/astro/typography/Heading.astro'
import SectionContainer from '@components/astro/containers/SectionContainer.astro'
import { cn } from '@utils/cn'
import { Image } from 'astro:assets'
import Button from '@components/astro/Button.astro'
import CommunityImg from '@assets/images/community-img.jpeg'
import PostReviewImg from '@assets/images/post-review.jpg'
import SupportContentImg from '@assets/images/support-content.jpg'
import MeetOnMeetupImg from '@assets/images/meet-on-meetup.jpg'
import ToolsForDevelopersImg from '@assets/images/tools-for-developers.jpg'

const groups = [
  {
    title: 'הקבוצה הראשית- דיונים על כל מה שמעבר לטכני',
    link: 'https://chat.whatsapp.com/CAQ7EnWJJQF6z3SLMhE8ot',
    image: CommunityImg,
    description: `מפתחים תותחים ותותחיות לא רק כותבים קוד!
    טל מוסקוביץ', אדיר קנדל ואורחים עוזרים למפתחים להישאר רלוונטיים ולפתח את עצמם:
- איך אני יכול להתבלט כמפתח, בצוות, בחברה ובחיפוש העבודה?
- איך מתכננים את הקפיצה הבאה בקריירה ולאן?
- איזה ערך מוסף ייחודי אני מביא לשולחן?
- איך לשפר את חווית הפיתוח שלי
כל מה שהוא פיתוח והוא לא טכני, על השולחן שלנו.
`,
  },
  {
    title: `פוסט ריוויו`,
    link: 'https://chat.whatsapp.com/GrhVRS1kGZVGKRXTMtktAq',
    image: PostReviewImg,
    description: `כמו קוד ריוויו, רק לפוסטים בלינקדאין. במקום ללמוד איך לכתוב בצורה אפקטיבית, ולקבל פידבק על פוסטים לפני פרסום.`,
  },
  {
    title: 'כותבים ומפרגנים לתוכן',
    link: 'https://chat.whatsapp.com/KnrinMGG99fFmgUTYboRHL',
    image: SupportContentImg,
    description: 'פרסמתם תוכן למפתחים ואתם צריכים חיבוק, לייק או תגובה? פרסמו אותו כאן',
  },
  {
    title: 'נפגשים במיטאפ',
    link: 'https://chat.whatsapp.com/DOINKYhviAbDSQXObQEfpj',
    image: MeetOnMeetupImg,
    description: 'כאן נפרסם מיטאפים וכנסים שווים באקוסיסטם, וגם אפשר לשאול מי בא ולאן',
  },
  {
    title: 'כלים למפתחים פרואקטיביים',
    link: 'https://chat.whatsapp.com/Kqwt0oItR30C01cnvedk4d',
    image: ToolsForDevelopersImg,
    description: `פה נדבר על כלים שעוזרים למפתחים בפיתוח אבל כמובן שלא רק!
גם כלים שעוזרים לנו להיות פרודוקטיביים ופרואקטיביים.`,
  },
]
---

<SectionContainer id="community">
  <Heading level={2} className="mb-8 text-center">קישורים לקבוצות הקהילה</Heading>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    {
      groups.map((group, index) => (
        <div
          class={cn(
            'group flex flex-col rounded-lg border border-white/5 bg-surface/50 p-5 transition-all duration-300 hover:border-accent/30 hover:bg-surface',
            index === 0 && 'md:col-span-2 md:flex-row md:items-center md:gap-6'
          )}>
          <!-- Image -->
          <div class={cn(
            'mx-auto mb-3 shrink-0 md:mb-0',
            index === 0 ? 'w-32' : 'w-20'
          )}>
            <ImageContainer showGradient gradientOnlyOnHover parentContainerClassName="self-center">
              <Image
                src={group.image}
                alt={group.title}
                width={index === 0 ? 128 : 80}
                height={index === 0 ? 128 : 80}
                class="aspect-square w-full rounded-lg object-cover"
              />
            </ImageContainer>
          </div>

          <!-- Content -->
          <div class="flex flex-1 flex-col gap-2">
            <Heading level={3} className="text-accent text-center text-base md:text-right">
              {group.title}
            </Heading>
            <p class="flex-1 whitespace-pre-line text-center text-sm text-gray-300 md:text-right">{group.description}</p>
            <div class="text-center md:text-right">
              <Button variant="link" size="sm" href={group.link} target="_blank" rel="noopener">
                הצטרף לקבוצה
              </Button>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</SectionContainer>
