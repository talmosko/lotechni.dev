---
// Newsletter subscription form — React component for client-side interactivity
import SectionContainer from '@components/astro/containers/SectionContainer.astro'
import Heading from '@components/astro/typography/Heading.astro'
import NewsletterForm from '@components/react/NewsletterForm'
---

<SectionContainer>
  <div class="mx-auto max-w-lg rounded-lg bg-surface p-8 shadow-inner shadow-white/10">
    <Heading level={5} className="mb-2 text-center"> 📬 אינסייטים שעולים מהשטח </Heading>
    <p class="mb-6 text-center text-base text-gray-400">
      כל שבועיים — תובנות ממה שקורה סביבנו ואיך זה משפיע עלינו כמפתחים. בלי ספאם, בלי שטויות.
    </p>

    <NewsletterForm client:load />
  </div>
</SectionContainer>
