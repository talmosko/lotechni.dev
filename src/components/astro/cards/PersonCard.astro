---
import CardContainer from '@components/astro/containers/CardContainer.astro'
import ImageContainer from '@components/astro/containers/ImageContainer.astro'
import Heading from '@components/astro/typography/Heading.astro'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { cn } from '@utils/cn'
import Icon from '@components/astro/Icon.astro'
import type { SocialLink } from '@data/types/icons'

interface Props {
  name: string
  image: ImageMetadata
  description: string
  socials: SocialLink[]
  subtitle?: string
  reversed?: boolean
  wide?: boolean
}

const { name, image, description, socials, subtitle, reversed = false, wide = false } = Astro.props

const rowClass = wide ? 'xl:flex-row' : 'lg:flex-row'
const rowReverseClass = wide && reversed ? 'xl:flex-row-reverse' : ''
const imageClass = wide
  ? 'self-start w-full xl:basis-1/3'
  : 'self-start w-full lg:basis-1/3 lg:max-w-48 max-w-64 mx-auto lg:mx-0'
const contentClass = wide ? 'xl:basis-2/3' : 'lg:basis-2/3'
---

<CardContainer className="group/card relative flex flex-col justify-between gap-2">
  <div class={cn('flex flex-col gap-4', rowClass, rowReverseClass)}>
    <ImageContainer
      showGradient
      gradientOnlyOnHover
      parentContainerClassName={imageClass}>
      <Image
        class="block aspect-square h-full w-full"
        src={image}
        width={image.width}
        height={image.height}
        alt={name}
        format="webp"
        quality={100}
      />
    </ImageContainer>
    <div class={cn('flex flex-col gap-4', contentClass)}>
      <div>
        <Heading level={3} className="text-accent">{name}</Heading>
        {subtitle && <p class="text-muted-foreground text-sm">{subtitle}</p>}
      </div>
      <p class="text-lg">{description}</p>
    </div>
  </div>
  <div class="flex gap-6 self-center">
    {socials.map(({ icon, url }) => (
      <a href={url} target="_blank" rel="noopener">
        <Icon icon={icon} className="hover:text-accent" />
      </a>
    ))}
  </div>
</CardContainer>
